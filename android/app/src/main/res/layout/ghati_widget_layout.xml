<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ghati_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/ghati_clock_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/ghati_text"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        android:contentDescription="Vedic Ghati Clock" />

    <TextView
        android:id="@+id/ghati_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:background="#CC0F0F1A"
        android:text="0 ಘ : 00 ವಿ : 00 ಅ" />

</RelativeLayout>
